# Required: GitHub OAuth App credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Required: OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Required: Secret for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET_KEY=

# Optional overrides (defaults shown)
APP_BASE_URL=http://localhost:8000
OPENROUTER_MODEL=anthropic/claude-3-haiku
VITE_API_URL=http://localhost:8000
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
SERVER_PORT=8000
CLIENT_PORT=3000
